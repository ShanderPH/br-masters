# =============================================================================
# BR Masters Backend - Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in your values:
#   cp backend/.env.example backend/.env
#
# IMPORTANT: Never commit .env or any file containing real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core (Required)
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=your-django-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# PostgreSQL (Required - Supabase or any Postgres instance)
# -----------------------------------------------------------------------------
POSTGRES_DB=br_masters
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Supabase Integration (Required for auth)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# -----------------------------------------------------------------------------
# Redis / Celery (Required for background tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# CORS (Required for frontend communication)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Railway-specific (set automatically by Railway, documented for reference)
# -----------------------------------------------------------------------------
# RAILWAY_PROCESS_TYPE=web          # web | worker | beat
# PORT=8000                         # Railway injects this
# WEB_WORKERS=2                     # Gunicorn worker count
# WEB_THREADS=2                     # Gunicorn thread count
# CELERY_LOG_LEVEL=info             # celery log level
# CELERY_WORKER_CONCURRENCY=2       # celery worker concurrency
# CELERY_WORKER_POOL=solo           # celery worker pool (solo for single-core)
