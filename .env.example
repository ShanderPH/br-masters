# =============================================================================
# BR Masters - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local or any file containing real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service Role Key (server-side only, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# -----------------------------------------------------------------------------
# SofaScore API via RapidAPI (Optional - falls back to mock data)
# Get your key from: https://rapidapi.com/sofascore/api/sofascore
# -----------------------------------------------------------------------------
# RAPIDAPI_KEY=your_rapidapi_key
# RAPIDAPI_HOST=sofascore.p.rapidapi.com

# -----------------------------------------------------------------------------
# Mercado Pago Configuration (Required for payments)
# Get your credentials from: https://www.mercadopago.com.br/developers/panel/app
# -----------------------------------------------------------------------------
# MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
# MERCADOPAGO_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your_public_key
# MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret_signature
# IMPORTANT: In production, set this to your actual domain (e.g., https://brmasters.febrate.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Tournament Configuration (Optional - defaults shown)
# -----------------------------------------------------------------------------
# BRASILEIRAO_TOURNAMENT_ID=325
# BRASILEIRAO_SEASON_ID=72034
